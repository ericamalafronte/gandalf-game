GEMINI_API_KEY=<YOUR_GEMINI_API_KEY_HERE>
# Note: Replace <YOUR_GEMINI_API_KEY_HERE> with your actual Gemini API key. Do not share this key publicly or commit it to version control.
GEMINI_MODEL=<YOUR_GEMINI_MODEL_HERE>
# Note: Replace <YOUR_GEMINI_MODEL_HERE> with the specific Gemini model otherwise using the default model. For example, you can specify "gemini-1.5-pro" or "gemini-2.0-pro" if you want to use those models instead of the default one.